# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google AI (Gemini / Imagen)
GOOGLE_API_KEY=your_google_api_key

# PortOne Payment
NEXT_PUBLIC_PORTONE_STORE_ID=your_store_id
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your_channel_key
PORTONE_API_SECRET=your_portone_api_secret

# Admin Configuration (서버사이드 전용, 클라이언트 노출 안됨)
ADMIN_EMAILS=admin@myaiprintshop.com,juno@myaiprintshop.com
# FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account",...} (선택: JSON 문자열)

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3300
